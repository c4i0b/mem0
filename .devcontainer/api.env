# Dev environment — all services mocked, no real API keys needed
USER=dev-user
API_KEY=dev-key

# LLM points to mock server (returns canned responses)
LLM_PROVIDER=openai
LLM_MODEL=mock
LLM_API_KEY=dev-key
LLM_BASE_URL=http://mock-server:11434/v1

# Embedder points to mock server (returns hash-based vectors)
EMBEDDER_PROVIDER=ollama
EMBEDDER_MODEL=embeddinggemma:300m-qat-q4_0
OLLAMA_BASE_URL=http://mock-server:11434

# Storage
DATABASE_URL=sqlite:///./openmemory-dev.db
FAISS_PATH=/data/faiss
EMBEDDING_DIMS=768
