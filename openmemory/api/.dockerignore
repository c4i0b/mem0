# Ignore git and CI
.git
.github

# Ignore environment files (contain API keys)
**/.env
**/.env.*
.env
.env.*

# Ignore all database files
**/*.db
**/*.sqlite
**/*.sqlite3

# Ignore logs
**/*.log

# Ignore runtime data
**/node_modules
**/__pycache__
**/.pytest_cache
**/.coverage
**/coverage

# Ignore Docker files (no need inside the image)
**/.dockerignore
**/Dockerfile
**/Dockerfile.*
**/docker-compose*.yml

# Ignore tests and docs (not needed at runtime)
tests/
README.md
