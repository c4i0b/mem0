# Ignore git and CI
.git
.github

# Ignore environment files (contain API keys)
**/.env
**/.env.*
.env
.env.*

# Ignore all database files
**/*.db
**/*.sqlite
**/*.sqlite3

# Ignore logs
**/*.log

# Ignore runtime data
**/node_modules
**/__pycache__
**/.pytest_cache
**/.coverage
**/coverage

# Ignore Docker runtime files
**/.dockerignore
**/Dockerfile
**/docker-compose*.yml 